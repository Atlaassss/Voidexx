# =====================================================
# VOIDEXX environment
# =====================================================
# All values below are OPTIONAL for local dev. The app
# runs in DEMO MODE when keys are missing. Wire them in
# as you graduate each subsystem.

# -- App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Database (Postgres / Supabase)
# When unset, the app skips persistence and works on
# ephemeral in-memory data — fine for visual demos.
DATABASE_URL=

# -- Clerk auth
# When BOTH keys are set, Clerk takes over. When unset,
# the app uses a demo session for local previews.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# -- Storage (S3 or Cloudflare R2)
# Required for real screenshot uploads. In demo mode the
# upload page falls back to a local blob URL.
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For R2 / non-AWS S3-compatibles, set the endpoint:
S3_ENDPOINT=
# CDN/public URL for objects (otherwise we synthesise one)
S3_PUBLIC_URL=

# -- AI providers
OPENAI_API_KEY=

# -- Stripe (Phase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -- Exchange (server-side only — never expose)
BINGX_API_KEY=
BINGX_API_SECRET=

# -- Redis (Phase 3 workers / rate limit)
REDIS_URL=
