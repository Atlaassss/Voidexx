# =====================================================
# VOIDEXX environment
# =====================================================
# All values below are OPTIONAL for local dev. The app
# runs in DEMO MODE when keys are missing. Wire them in
# as you graduate each subsystem.

# -- App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- UI flags
# Hide the yellow "Demo mode" banner that lists unwired subsystems
# at the top of every page. Useful when showing the UI to clients/
# stakeholders without setting up real backends yet. Set to "1" to
# hide; leave blank during dev so you can see what's still wired.
#
# Note: this only hides the BANNER. Buttons that hit unconfigured
# services (e.g. Stripe Checkout) still return helpful 503s — that's
# by design, you'd notice fast when a real customer can't pay.
#
# Users can also dismiss the banner per-session via the × button on
# the banner itself, without setting any env vars.
NEXT_PUBLIC_HIDE_DEMO_BANNER=

# -- Database (Postgres / Supabase)
# When unset, the app skips persistence and works on
# ephemeral in-memory data — fine for visual demos.
DATABASE_URL=

# -- Clerk auth
# When BOTH keys are set, Clerk takes over. When unset,
# the app uses a demo session for local previews.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# -- Storage (S3 or Cloudflare R2)
# Required for real screenshot uploads. In demo mode the
# upload page falls back to a local blob URL.
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For R2 / non-AWS S3-compatibles, set the endpoint:
S3_ENDPOINT=
# CDN/public URL for objects (otherwise we synthesise one)
S3_PUBLIC_URL=

# -- AI providers
# When set, the autopsy pipeline runs gpt-4o vision + verdict passes.
# When unset, the orchestrator returns one of 4 deterministic mock
# archetypes keyed off uploadId hash so demos look diverse.
OPENAI_API_KEY=

# -- Stripe (Phase 4)
# When set, /dashboard/billing wires real Stripe Checkout. Without
# these, the upgrade buttons show a demo notice and the webhook
# acks-and-drops events. The webhook secret is required for production
# but optional in dev (CLI `stripe listen` works without verification).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_OPERATOR=
STRIPE_PRICE_DESK=
# URL Stripe should send the user to after they close the customer
# portal. Defaults to ${NEXT_PUBLIC_APP_URL}/dashboard/billing.
STRIPE_PORTAL_RETURN_URL=

# -- PayMongo (Phase 7.1 — Philippine billing rail)
# Covers GCash, Maya, GrabPay, BPI/BDO/UnionBank online + cards
# (Visa/MC/JCB/Amex). Independent of Stripe — either or both can be live.
#
# Get the secret key from https://dashboard.paymongo.com → Developers →
# API Keys. Test keys (sk_test_*) talk to PayMongo's sandbox; live keys
# (sk_live_*) require account activation + verified bank account.
PAYMONGO_SECRET_KEY=

# Public key — exposed to the browser. Phase 7.1 uses it nowhere
# directly (we attach methods server-side) but Phase 7.2's card form
# will need it for tokenisation. Setting it now is harmless.
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=

# Webhook signing secret. Get from Dashboard → Developers → Webhooks
# after creating an endpoint pointing at:
#   https://YOUR-DOMAIN/api/billing/paymongo/webhook
# In production this MUST be set; in dev the route falls through with
# a warning so local PayMongo CLI testing works.
PAYMONGO_WEBHOOK_SECRET=

# Plan prices in CENTAVOS (PHP × 100). Override the USD→PHP fallback
# (×56) for fine-grained control. Defaults are computed in plans.ts:
#   OPERATOR ≈ 134400 centavos (₱1,344)
#   DESK     ≈ 442400 centavos (₱4,424)
PAYMONGO_PRICE_OPERATOR_PHP=
PAYMONGO_PRICE_DESK_PHP=

# -- Exchange (server-side only — never expose)
# Required for persisting connected exchanges. AES-256 key for
# encrypting API secrets at rest. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EXCHANGE_ENCRYPTION_KEY=

# Override the BingX API base URL (e.g. for testnet or a regional mirror).
# Leave unset to use https://open-api.bingx.com.
BINGX_BASE_URL=

# Legacy / per-environment defaults — only used by older code paths.
# Real per-user keys live in the encrypted ExchangeConnection rows.
BINGX_API_KEY=
BINGX_API_SECRET=

# -- Redis (Phase 3 workers / rate limit)
REDIS_URL=


# -- Vercel Cron (Phase 6)
# Secret used to authenticate cron job requests. Vercel injects this
# automatically. For local testing, set any value and pass it as
# Authorization: Bearer <value> when hitting /api/cron/*.
CRON_SECRET=


# -- Email (Phase 7 — transactional)
# Resend API key for welcome / autopsy-ready / plan-changed emails.
# When unset, every send() logs the would-be email and returns success
# so the rest of the app stays wired without burning real mail.
RESEND_API_KEY=

# Sender identity. Should be a verified Resend domain in production.
EMAIL_FROM_ADDRESS="Voidexx <ops@voidexx.io>"
